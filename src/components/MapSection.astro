---
interface Rider {
  name: string;
  tkid: string;
  photo: string;
  location: string;
  message: string;
}

interface Marker {
  lat: number;
  lng: number;
  riders: Rider[];
}

interface Customer {
  lat: number;
  lng: number;
  city: string;
  country: string;
}

interface Props {
  markers: Marker[];
  customers?: Customer[];
}

const { markers, customers = [] } = Astro.props;
---

<div class="map-container notranslate" translate="no">
  <div id="map" role="img" aria-label="World map showing TRACKID duck sticker sightings across cities and countries" style="height: 400px; width: 100%; background: var(--surface); border: 1px solid var(--weld);"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />

<script is:inline define:vars={{ markers, customers }}>
  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

  function styleUrl(dark) {
    return 'https://tiles.openfreemap.org/styles/' + (dark ? 'dark' : 'positron');
  }

  var script = document.createElement('script');
  script.src = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js';
  script.onload = function() {
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    var map = new maplibregl.Map({
      container: 'map',
      style: styleUrl(isDark),
      center: [0, 30],
      zoom: 1,
      attributionControl: false,
      cooperativeGestures: false,
    });

    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-left');
    map.addControl(new maplibregl.AttributionControl({
      compact: true,
      customAttribution: '<a href="https://openfreemap.org">OpenFreeMap</a> &copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>',
    }));

    // Hide all label/symbol layers for a clean, label-free aesthetic.
    // Re-runs on every style load since setStyle replaces all layers.
    function hideLabels() {
      var layers = map.getStyle().layers || [];
      layers.forEach(function(layer) {
        if (layer.type === 'symbol') {
          try { map.setLayoutProperty(layer.id, 'visibility', 'none'); } catch (e) {}
        }
      });
    }
    map.on('style.load', hideLabels);

    var observer = new MutationObserver(function() {
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      map.setStyle(styleUrl(dark));
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    function popupOpts(maxWidth) {
      return {
        offset: 20,
        closeButton: true,
        closeOnClick: true,
        maxWidth: maxWidth + 'px',
        className: 'trackid-popup',
      };
    }

    // Customer markers (pulse dot)
    customers.forEach(function(c) {
      var el = document.createElement('div');
      el.className = 'trackid-marker';
      el.innerHTML = '<div class="pulse-dot"></div>';

      var html =
        '<div style="padding:8px 10px;">' +
          '<div style="font-family:monospace;font-size:11px;color:#D4213D;letter-spacing:1px;">STICKER SPOTTED</div>' +
          '<div style="font-family:monospace;font-size:12px;color:#8A8279;margin-top:4px;">' + esc(c.city) + ', ' + esc(c.country) + '</div>' +
        '</div>';

      new maplibregl.Marker({ element: el, anchor: 'center' })
        .setLngLat([c.lng, c.lat])
        .setPopup(new maplibregl.Popup(popupOpts(200)).setHTML(html))
        .addTo(map);
    });

    // Rider markers — grouped by city
    markers.forEach(function(m) {
      var count = m.riders.length;
      var el = document.createElement('div');
      el.className = 'trackid-marker';

      if (count === 1) {
        el.innerHTML = '<div style="font-size:32px;line-height:1;filter:drop-shadow(0 1px 3px rgba(0,0,0,0.3));">🦆</div>';
      } else {
        var html = '<div style="position:relative;width:52px;height:44px;">';
        for (var i = 0; i < Math.min(count, 3); i++) {
          html += '<div style="position:absolute;font-size:26px;line-height:1;filter:drop-shadow(0 1px 3px rgba(0,0,0,0.3));left:' + (i * 10) + 'px;top:' + (i * 6) + 'px;">🦆</div>';
        }
        html += '</div>';
        el.innerHTML = html;
      }

      var popupHtml = '<div style="max-height:220px;overflow-y:auto;min-width:180px;">';
      m.riders.forEach(function(r, idx) {
        var msgHtml = r.message ? '<div style="font-size:12px;color:#8A8279;margin-top:6px;line-height:1.4;font-style:italic;">"' + esc(r.message) + '"</div>' : '';
        if (idx > 0) popupHtml += '<div style="border-top:1px solid #ddd;"></div>';
        popupHtml +=
          '<div>' +
            '<img src="' + esc(r.photo) + '" alt="' + esc(r.name) + '" style="width:100%;height:90px;object-fit:cover;display:block;" />' +
            '<div style="padding:8px 4px 4px;">' +
              '<div style="font-family:monospace;color:#D4213D;font-size:11px;letter-spacing:1px;">' + esc(r.tkid) + '</div>' +
              '<div style="font-weight:500;font-size:13px;margin-top:2px;">' + esc(r.name) + '</div>' +
              '<div style="font-family:monospace;font-size:11px;color:#8A8279;margin-top:2px;">' + esc(r.location) + '</div>' +
              msgHtml +
            '</div>' +
          '</div>';
      });
      popupHtml += '</div>';

      var riderPopup = new maplibregl.Popup(popupOpts(220)).setHTML(popupHtml);
      new maplibregl.Marker({ element: el, anchor: 'center' })
        .setLngLat([m.lng, m.lat])
        .setPopup(riderPopup)
        .addTo(map);

      // Pan marker into the lower half so popup has room to open above it.
      riderPopup.on('open', function() {
        map.easeTo({ center: [m.lng, m.lat], offset: [0, 100], duration: 300 });
      });
    });

    // Fit to all points after style loads
    map.on('load', function() {
      var allPoints = []
        .concat(markers.map(function(m) { return [m.lng, m.lat]; }))
        .concat(customers.map(function(c) { return [c.lng, c.lat]; }));
      if (allPoints.length === 0) return;
      var bounds = allPoints.reduce(function(b, p) {
        return b.extend(p);
      }, new maplibregl.LngLatBounds(allPoints[0], allPoints[0]));
      map.fitBounds(bounds, { padding: 50, maxZoom: 6, duration: 0 });
    });
  };
  document.head.appendChild(script);
</script>

<style>
  .map-container {
    margin-top: 24px;
  }

  .map-container :global(.maplibregl-popup-content) {
    border-radius: 0;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .map-container :global(.maplibregl-popup-tip) {
    display: none;
  }

  .map-container :global(.maplibregl-popup-close-button) {
    font-size: 18px;
    padding: 2px 8px;
    color: #8A8279;
  }

  .map-container :global(.trackid-marker) {
    cursor: pointer;
  }

  .map-container :global(.pulse-dot) {
    width: 6px;
    height: 6px;
    background: #E8820C;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(232, 130, 12, 0.6);
    animation: pulse-ring 2s ease-out infinite;
  }

  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(232, 130, 12, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(232, 130, 12, 0); }
    100% { box-shadow: 0 0 0 0 rgba(232, 130, 12, 0); }
  }
</style>
