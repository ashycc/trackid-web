---
interface Rider {
  lat: number;
  lng: number;
  name: string;
  tkid: string;
  photo: string;
  location: string;
  message: string;
}

interface Props {
  riders: Rider[];
}

const { riders } = Astro.props;
---

<div class="map-container notranslate" translate="no">
  <div id="map" style="height: 400px; width: 100%; background: var(--surface); border: 1px solid var(--weld);"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script is:inline define:vars={{ riders }}>
  // Load Leaflet from CDN
  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = () => {
    const map = L.map('map', {
      scrollWheelZoom: false,
      attributionControl: false,
    }).setView([30, 0], 2);

    L.control.attribution({ prefix: '<a href="https://leafletjs.com">Leaflet</a>' }).addTo(map);

    // Pick tile style based on current theme
    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    var tileStyle = isDark ? 'dark_nolabels' : 'light_nolabels';
    var tileLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/' + tileStyle + '/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
      maxZoom: 18,
    }).addTo(map);

    // Swap tiles when theme changes
    var observer = new MutationObserver(function() {
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      var style = dark ? 'dark_nolabels' : 'light_nolabels';
      tileLayer.setUrl('https://{s}.basemaps.cartocdn.com/' + style + '/{z}/{x}/{y}{r}.png');
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // Signal Red markers
    const redIcon = L.divIcon({
      className: 'trackid-marker',
      html: '<div style="width:12px;height:12px;background:#D4213D;border:2px solid #0D0D0D;border-radius:0;"></div>',
      iconSize: [12, 12],
      iconAnchor: [6, 6],
    });

    riders.forEach((r) => {
      const msgHtml = r.message ? `<div style="font-size:12px;color:#8A8279;margin-top:6px;line-height:1.4;font-style:italic;">"${r.message}"</div>` : '';
      L.marker([r.lat, r.lng], { icon: redIcon })
        .bindPopup(
          `<div style="min-width:180px;">` +
            `<img src="${r.photo}" style="width:100%;height:120px;object-fit:cover;display:block;" />` +
            `<div style="padding:8px 4px 4px;">` +
              `<div style="font-family:monospace;color:#D4213D;font-size:11px;letter-spacing:1px;">${r.tkid}</div>` +
              `<div style="font-weight:500;font-size:13px;margin-top:2px;">${r.name}</div>` +
              `<div style="font-family:monospace;font-size:11px;color:#8A8279;margin-top:2px;">${r.location}</div>` +
              msgHtml +
            `</div>` +
          `</div>`,
          { maxWidth: 220, minWidth: 180, className: 'trackid-popup' }
        )
        .addTo(map);
    });

    if (riders.length > 0) {
      const bounds = L.latLngBounds(riders.map((r) => [r.lat, r.lng]));
      map.fitBounds(bounds, { padding: [50, 50], maxZoom: 6 });
    }
  };
  document.head.appendChild(script);
</script>

<style>
  .map-container {
    margin-top: 24px;
  }

  /* Override Leaflet popup styles */
  .map-container :global(.leaflet-popup-content-wrapper) {
    border-radius: 0;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    padding: 0;
    overflow: hidden;
  }

  .map-container :global(.leaflet-popup-content) {
    margin: 0;
  }

  .map-container :global(.leaflet-popup-tip) {
    display: none;
  }
</style>
