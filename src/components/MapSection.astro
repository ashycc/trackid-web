---
interface Rider {
  name: string;
  tkid: string;
  photo: string;
  location: string;
  message: string;
}

interface Marker {
  lat: number;
  lng: number;
  riders: Rider[];
}

interface Customer {
  lat: number;
  lng: number;
  city: string;
  country: string;
}

interface Props {
  markers: Marker[];
  customers?: Customer[];
}

const { markers, customers = [] } = Astro.props;
---

<div class="map-container notranslate" translate="no">
  <div id="map" role="img" aria-label="World map showing TRACKID duck sticker sightings across cities and countries" style="height: 400px; width: 100%; background: var(--surface); border: 1px solid var(--weld);"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script is:inline define:vars={{ markers, customers }}>
  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

  var script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = function() {
    var map = L.map('map', {
      scrollWheelZoom: true,
      touchZoom: true,
      zoomSnap: 0,
      zoomDelta: 1,
      wheelPxPerZoomLevel: 60,
      inertia: true,
      inertiaDeceleration: 2000,
      inertiaMaxSpeed: 1500,
      easeLinearity: 0.25,
      zoomAnimation: true,
      fadeAnimation: true,
      markerZoomAnimation: true,
      attributionControl: false,
    }).setView([30, 0], 2);

    L.control.attribution({ prefix: '<a href="https://leafletjs.com">Leaflet</a>' }).addTo(map);

    var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    var tileStyle = isDark ? 'dark_nolabels' : 'light_nolabels';
    var tileLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/' + tileStyle + '/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
      maxZoom: 18,
    }).addTo(map);

    var observer = new MutationObserver(function() {
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      var style = dark ? 'dark_nolabels' : 'light_nolabels';
      tileLayer.setUrl('https://{s}.basemaps.cartocdn.com/' + style + '/{z}/{x}/{y}{r}.png');
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // Customer markers (pulse dot)
    var dotIcon = L.divIcon({
      className: 'trackid-marker',
      html: '<div class="pulse-dot"></div>',
      iconSize: [8, 8],
      iconAnchor: [4, 4],
    });

    customers.forEach(function(c) {
      L.marker([c.lat, c.lng], { icon: dotIcon })
        .bindPopup(
          '<div style="padding:8px 10px;">' +
            '<div style="font-family:monospace;font-size:11px;color:#D4213D;letter-spacing:1px;">STICKER SPOTTED</div>' +
            '<div style="font-family:monospace;font-size:12px;color:#8A8279;margin-top:4px;">' + esc(c.city) + ', ' + esc(c.country) + '</div>' +
          '</div>',
          { maxWidth: 200, className: 'trackid-popup' }
        )
        .addTo(map);
    });

    // Rider markers — grouped by city
    markers.forEach(function(m) {
      var count = m.riders.length;

      // Stacked ducks for multi-rider cities
      var iconHtml;
      if (count === 1) {
        iconHtml = '<div style="font-size:20px;line-height:1;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.3));">🦆</div>';
      } else {
        iconHtml = '<div style="position:relative;width:32px;height:28px;">';
        for (var i = 0; i < Math.min(count, 3); i++) {
          iconHtml += '<div style="position:absolute;font-size:16px;line-height:1;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.3));left:' + (i * 6) + 'px;top:' + (i * 4) + 'px;">🦆</div>';
        }
        iconHtml += '</div>';
      }

      var duckIcon = L.divIcon({
        className: 'trackid-marker',
        html: iconHtml,
        iconSize: count > 1 ? [32, 28] : [24, 24],
        iconAnchor: count > 1 ? [16, 14] : [12, 12],
      });

      // Build scrollable popup with all riders
      var popupHtml = '<div style="max-height:280px;overflow-y:auto;min-width:180px;">';
      m.riders.forEach(function(r, idx) {
        var msgHtml = r.message ? '<div style="font-size:12px;color:#8A8279;margin-top:6px;line-height:1.4;font-style:italic;">"' + esc(r.message) + '"</div>' : '';
        if (idx > 0) popupHtml += '<div style="border-top:1px solid #ddd;"></div>';
        popupHtml +=
          '<div>' +
            '<img src="' + esc(r.photo) + '" alt="' + esc(r.name) + '" style="width:100%;height:120px;object-fit:cover;display:block;" />' +
            '<div style="padding:8px 4px 4px;">' +
              '<div style="font-family:monospace;color:#D4213D;font-size:11px;letter-spacing:1px;">' + esc(r.tkid) + '</div>' +
              '<div style="font-weight:500;font-size:13px;margin-top:2px;">' + esc(r.name) + '</div>' +
              '<div style="font-family:monospace;font-size:11px;color:#8A8279;margin-top:2px;">' + esc(r.location) + '</div>' +
              msgHtml +
            '</div>' +
          '</div>';
      });
      popupHtml += '</div>';

      L.marker([m.lat, m.lng], { icon: duckIcon })
        .bindPopup(popupHtml, { maxWidth: 220, minWidth: 180, className: 'trackid-popup' })
        .addTo(map);
    });

    var allPoints = [
      ...markers.map(function(m) { return [m.lat, m.lng]; }),
      ...customers.map(function(c) { return [c.lat, c.lng]; }),
    ];
    if (allPoints.length > 0) {
      var bounds = L.latLngBounds(allPoints);
      map.fitBounds(bounds, { padding: [50, 50], maxZoom: 6 });
    }

    var mapEl = document.getElementById('map');
    function fixTileAlts() {
      mapEl.querySelectorAll('.leaflet-tile-container img:not([alt])').forEach(function(img) {
        img.setAttribute('alt', '');
        img.setAttribute('role', 'presentation');
      });
    }
    fixTileAlts();
    new MutationObserver(fixTileAlts).observe(mapEl, { childList: true, subtree: true });
  };
  document.head.appendChild(script);
</script>

<style>
  .map-container {
    margin-top: 24px;
  }

  .map-container :global(.leaflet-popup-content-wrapper) {
    border-radius: 0;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13px;
    padding: 0;
    overflow: hidden;
  }

  .map-container :global(.leaflet-popup-content) {
    margin: 0;
  }

  .map-container :global(.leaflet-popup-tip) {
    display: none;
  }

  .map-container :global(.pulse-dot) {
    width: 6px;
    height: 6px;
    background: #E8820C;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(232, 130, 12, 0.6);
    animation: pulse-ring 2s ease-out infinite;
  }

  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(232, 130, 12, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(232, 130, 12, 0); }
    100% { box-shadow: 0 0 0 0 rgba(232, 130, 12, 0); }
  }
</style>
