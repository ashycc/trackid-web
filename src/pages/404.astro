---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TRACKID — Not Found" description="Page not found. Head back to the TRACKID rider registry.">
  <section class="section" style="text-align: center; padding: 120px 0;">
    <span class="section-label">Error 404</span>
    <h1 class="display" style="font-size: 64px; font-weight: 700; letter-spacing: 6px; margin-top: 16px; line-height: 1.1;">
      Wrong<br />Turn
    </h1>
    <p style="color: var(--muted); margin-top: 24px; max-width: 400px; margin-left: auto; margin-right: auto;">
      This route doesn't exist in the <span class="notranslate">REGISTRY</span>. Head back to the gallery.
    </p>
    <a href="/" class="btn btn-outline notranslate" style="margin-top: 32px;">Back to Registry</a>
  </section>
</Layout>
