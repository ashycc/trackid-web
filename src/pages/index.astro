---
import Layout from '../layouts/Layout.astro';
import RegistryCard from '../components/RegistryCard.astro';
import StatsBar from '../components/StatsBar.astro';
import MapSection from '../components/MapSection.astro';
import { supabaseAdmin } from '../lib/supabase';

export const prerender = false;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;

// Fetch approved submissions
const { data: submissions } = await supabaseAdmin
  .from('submissions')
  .select('*')
  .eq('status', 'approved')
  .order('registry_id', { ascending: false });

const riders = submissions ?? [];

// Compute stats
const totalRiders = riders.length;
const countries = new Set(riders.map(r => r.location.split(',').pop()?.trim()).filter(Boolean)).size;
const cities = new Set(riders.map(r => r.location.split(',')[0]?.trim()).filter(Boolean)).size;

function photoUrl(path: string): string {
  return `${supabaseUrl}/storage/v1/object/public/rider-photos/${path}`;
}

// Riders with coordinates for the map
const mapRiders = riders
  .filter(r => r.latitude && r.longitude)
  .map(r => ({
    lat: r.latitude,
    lng: r.longitude,
    name: r.rider_name,
    tkid: `TKID-${String(r.registry_id).padStart(4, '0')}`,
    photo: photoUrl(r.photo_path),
    location: r.location,
    message: r.message || '',
  }));
---

<Layout title="TRACKID — The Dove Became a Duck" description="TRACKID is a Beijing-based fixed gear brand. Browse the rider gallery, spot the roast duck sticker on steel frames worldwide, and join the flock." ogType="website">
  <!-- Hero -->
  <section class="section">
    <div class="section-header">
      <span class="section-label notranslate">TRACKID</span>
      <h1 class="display" style="font-size: 48px; font-weight: 700; letter-spacing: 4px; margin-top: 16px; line-height: 1.1;">
        The Dove<br />Became a Duck.
      </h1>
      <p style="max-width: 600px; margin-top: 20px; line-height: 1.7; color: var(--muted);">
        If you know the Columbus dove, you know what this sticker is. If you don't — it's a Beijing roast duck on a fixie, and it's already riding in dozens of countries. Show us where yours ended up.
      </p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="section-header">
      <span class="section-label">The Flock</span>
      <h2 class="display" style="font-size: 32px; font-weight: 700; letter-spacing: 3px; margin-top: 16px; line-height: 1.1;">
        Every duck has a story.<br />Every frame has a city.
      </h2>
    </div>

    <StatsBar totalRiders={totalRiders} countries={countries} cities={cities} />

    {mapRiders.length > 0 && <MapSection riders={mapRiders} />}

    {riders.length === 0 ? (
      <p style="color: var(--muted); margin-top: 32px;">No ducks spotted yet. <a href="/upload" style="color: var(--signal-red);">Be the first.</a></p>
    ) : (
      <div class="registry-grid" style="margin-top: 32px;">
        {riders.map(rider => (
          <RegistryCard
            registryId={rider.registry_id}
            riderName={rider.rider_name}
            location={rider.location}
            photoUrl={photoUrl(rider.photo_path)}
            message={rider.message}
          />
        ))}
      </div>
    )}
  </section>

  <!-- Lightbox -->
  <div class="lightbox-overlay" id="lightbox" style="display: none;">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
    <div class="lightbox-content">
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      <div class="lightbox-info">
        <div class="lightbox-tkid" id="lightbox-tkid"></div>
        <div class="lightbox-rider" id="lightbox-rider"></div>
        <div class="lightbox-loc" id="lightbox-loc"></div>
        <div class="lightbox-msg" id="lightbox-msg"></div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="section" style="text-align: center; padding: 80px 0;">
    <p style="font-size: 20px; font-weight: 600; font-family: 'Space Grotesk', sans-serif; letter-spacing: 2px;">
      No duck yet? Fix that.
    </p>
    <a href="https://www.aliexpress.com/item/1005010774387015.html" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: 20px;">
      Grab one on AliExpress &rarr;
    </a>
  </section>
</Layout>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .lightbox-close {
    position: absolute;
    top: 16px;
    right: 24px;
    background: none;
    border: none;
    color: #fff;
    font-size: 36px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-content {
    max-width: 720px;
    width: 100%;
    background: var(--paper);
    overflow: hidden;
  }

  .lightbox-img {
    width: 100%;
    max-height: 60vh;
    object-fit: contain;
    display: block;
    background: #000;
  }

  .lightbox-info {
    padding: 20px 24px;
  }

  .lightbox-tkid {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--signal-red);
    letter-spacing: 1px;
  }

  .lightbox-rider {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 16px;
    font-weight: 500;
    margin-top: 4px;
  }

  .lightbox-loc {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  .lightbox-msg {
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
  }

  .lightbox-msg:empty {
    display: none;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbTkid = document.getElementById('lightbox-tkid')!;
  const lbRider = document.getElementById('lightbox-rider')!;
  const lbLoc = document.getElementById('lightbox-loc')!;
  const lbMsg = document.getElementById('lightbox-msg')!;
  const lbClose = document.getElementById('lightbox-close')!;

  document.querySelectorAll('.registry-card').forEach(card => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      lbImg.src = el.dataset.photo || '';
      lbImg.alt = el.dataset.rider || '';
      lbTkid.textContent = el.dataset.tkid || '';
      lbRider.textContent = el.dataset.rider || '';
      lbLoc.textContent = el.dataset.location || '';
      lbMsg.textContent = el.dataset.message || '';
      lightbox.style.display = 'flex';
    });
  });

  lbClose.addEventListener('click', () => {
    lightbox.style.display = 'none';
  });

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) lightbox.style.display = 'none';
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') lightbox.style.display = 'none';
  });
</script>

