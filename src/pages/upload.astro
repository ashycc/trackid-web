---
import Layout from '../layouts/Layout.astro';

const hcaptchaSiteKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY || '';
---

<Layout title="TRACKID — Show Us Your Duck" description="Upload your duck sticker photo and join the TRACKID rider registry. Show the world where your Beijing roast duck has landed.">
  <section class="section">
    <div class="section-header">
      <span class="section-label">Upload</span>
      <h1 class="display" style="font-size: 48px; font-weight: 700; letter-spacing: 4px; margin-top: 16px; line-height: 1.1;">
        Show Us<br />Your Duck
      </h1>
      <p style="max-width: 600px; margin-top: 16px; color: var(--muted); line-height: 1.7;">
        Got a <span class="notranslate">TRACKID</span> duck on your frame? Your helmet? Your toolbox? Take a photo and throw it up here. Blurry is fine. Dirty is better. This isn't a product catalog — it's a map of everywhere this duck has landed.
      </p>
    </div>
  </section>

  <section class="section">
    <div id="upload-alert" style="display: none;"></div>

    <form id="upload-form" class="upload-form" enctype="multipart/form-data">
      <div class="input-group">
        <label class="input-label" for="photo">Photos <span class="label-hint">(up to 3)</span></label>
        <div class="upload-dropzone" id="dropzone">
          <div class="dropzone-icon">&#x2191;</div>
          <div class="dropzone-text">Drop up to 3 photos here or click to browse</div>
          <input type="file" id="photo" name="photos" accept="image/jpeg,image/png,image/webp" multiple style="position: absolute; width: 0; height: 0; opacity: 0; overflow: hidden;" />
        </div>
        <div class="preview-grid" id="preview-grid"></div>
        <p class="preview-hint" id="preview-hint" style="display: none;">Drag to reorder — the first photo will be your cover (admin can change it later).</p>
      </div>

      <div class="input-group">
        <label class="input-label" for="rider_name">Rider Name</label>
        <input class="input-field" type="text" id="rider_name" name="rider_name" placeholder="Your name" required />
      </div>

      <div class="input-group">
        <label class="input-label" for="location">Location</label>
        <input class="input-field" type="text" id="location" name="location" placeholder="City, Country" required />
      </div>

      <div class="input-group">
        <label class="input-label" for="email">Email</label>
        <input class="input-field" type="email" id="email" name="email" placeholder="Get notified when your ride goes live" required />
      </div>

      <div class="input-group">
        <label class="input-label" for="message">Say Something (optional)</label>
        <textarea class="input-field" id="message" name="message" rows="3" placeholder="Why the duck? What are you riding? Whatever."></textarea>
      </div>

      {hcaptchaSiteKey && (
        <div class="input-group" id="captcha-group">
          <div class="h-captcha" data-sitekey={hcaptchaSiteKey}></div>
        </div>
      )}

      <button type="submit" class="btn btn-primary" id="submit-btn">Send the Duck 🦆</button>
    </form>

    {hcaptchaSiteKey && (
      <script is:inline src="https://js.hcaptcha.com/1/api.js" async defer></script>
    )}
  </section>

  <!-- Success Modal -->
  <div class="modal-overlay" id="success-modal" style="display: none;">
    <div class="modal-box">
      <div class="modal-icon">🦆</div>
      <h2 class="modal-title">Duck Received!</h2>
      <p class="modal-text">Your photo is in the queue. We'll review it and add it to the flock once it's approved. No refunds.</p>
      <button class="btn btn-primary modal-close" id="modal-close">Got It</button>
    </div>
  </div>
</Layout>

<style>
  .upload-form {
    max-width: 560px;
  }

  .label-hint {
    font-weight: 400;
    color: var(--muted);
    text-transform: none;
    letter-spacing: 0;
    margin-left: 4px;
  }

  .upload-dropzone.drag-over {
    border-color: var(--signal-red);
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 12px;
  }

  .preview-grid:empty {
    display: none;
  }

  .preview-item {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--weld);
    background: var(--surface);
    overflow: hidden;
    cursor: grab;
    transition: opacity 0.15s ease, border-color 0.15s ease;
  }

  .preview-item.dragging {
    opacity: 0.4;
    cursor: grabbing;
  }

  .preview-item.drag-over {
    border-color: var(--signal-red);
    border-width: 2px;
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .preview-order {
    position: absolute;
    top: 4px;
    left: 4px;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: var(--signal-red);
    color: #fff;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    pointer-events: none;
  }

  .preview-remove {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-remove:hover {
    background: var(--signal-red);
  }

  .preview-move {
    position: absolute;
    bottom: 4px;
    width: 24px;
    height: 24px;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    border: none;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .preview-move:hover:not([disabled]) {
    background: var(--signal-red);
  }

  .preview-move[disabled] {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .preview-move.left {
    left: 4px;
  }

  .preview-move.right {
    right: 4px;
  }

  .preview-hint {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--muted);
    margin: 8px 0 0;
  }

  .btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .modal-box {
    background: var(--paper);
    border: 1px solid var(--weld);
    padding: 48px 40px;
    max-width: 420px;
    width: 90%;
    text-align: center;
  }

  .modal-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .modal-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .modal-text {
    font-size: 14px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 28px;
  }

  .modal-close {
    min-width: 140px;
  }
</style>

<script>
  const MAX_PHOTOS = 3;
  const MAX_SIZE = 10 * 1024 * 1024;
  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

  const form = document.getElementById('upload-form') as HTMLFormElement;
  const dropzone = document.getElementById('dropzone')!;
  const fileInput = document.getElementById('photo') as HTMLInputElement;
  const previewGrid = document.getElementById('preview-grid')!;
  const previewHint = document.getElementById('preview-hint')!;
  const dropzoneText = dropzone.querySelector('.dropzone-text')!;
  const alertBox = document.getElementById('upload-alert')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const modal = document.getElementById('success-modal')!;
  const modalClose = document.getElementById('modal-close')!;

  let selected: File[] = [];

  dropzone.addEventListener('click', (e) => {
    // Avoid re-opening picker if user clicked a remove button (stopped below too, but double-safe)
    if ((e.target as HTMLElement).closest('.preview-remove')) return;
    fileInput.click();
  });

  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('drag-over');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('drag-over');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('drag-over');
    if (e.dataTransfer?.files.length) {
      addFiles(Array.from(e.dataTransfer.files));
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) {
      addFiles(Array.from(fileInput.files));
      // Clear the input so picking the same file again re-fires change
      fileInput.value = '';
    }
  });

  function addFiles(files: File[]) {
    hideAlert();
    const remaining = MAX_PHOTOS - selected.length;
    if (remaining <= 0) {
      showAlert('error', `Maximum ${MAX_PHOTOS} photos.`);
      return;
    }

    const accepted: File[] = [];
    for (const f of files) {
      if (!ALLOWED_TYPES.includes(f.type)) {
        showAlert('error', `"${f.name}" skipped — only JPEG, PNG, WebP accepted.`);
        continue;
      }
      if (f.size > MAX_SIZE) {
        showAlert('error', `"${f.name}" skipped — each file must be under 10MB.`);
        continue;
      }
      accepted.push(f);
      if (accepted.length >= remaining) break;
    }

    if (files.length > remaining + (files.length - accepted.length)) {
      // User dropped more than allowed
      showAlert('error', `Only the first ${MAX_PHOTOS} photos are kept.`);
    }

    selected = selected.concat(accepted).slice(0, MAX_PHOTOS);
    renderPreviews();
  }

  function removeAt(idx: number) {
    selected.splice(idx, 1);
    renderPreviews();
  }

  function moveItem(from: number, to: number) {
    if (from === to || from < 0 || to < 0 || from >= selected.length || to >= selected.length) return;
    const [item] = selected.splice(from, 1);
    selected.splice(to, 0, item);
    renderPreviews();
  }

  let dragFrom = -1;

  function renderPreviews() {
    previewGrid.innerHTML = '';
    selected.forEach((file, idx) => {
      const item = document.createElement('div');
      item.className = 'preview-item';
      item.draggable = true;
      item.dataset.idx = String(idx);

      const img = document.createElement('img');
      const reader = new FileReader();
      reader.onload = (e) => { img.src = String(e.target?.result || ''); };
      reader.readAsDataURL(file);
      img.alt = file.name;

      const order = document.createElement('div');
      order.className = 'preview-order';
      order.textContent = String(idx + 1);

      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'preview-remove';
      remove.setAttribute('aria-label', 'Remove photo');
      remove.textContent = '×';
      remove.addEventListener('click', (e) => {
        e.stopPropagation();
        removeAt(idx);
      });

      const left = document.createElement('button');
      left.type = 'button';
      left.className = 'preview-move left';
      left.setAttribute('aria-label', 'Move left');
      left.textContent = '‹';
      left.disabled = idx === 0;
      left.addEventListener('click', (e) => {
        e.stopPropagation();
        moveItem(idx, idx - 1);
      });

      const right = document.createElement('button');
      right.type = 'button';
      right.className = 'preview-move right';
      right.setAttribute('aria-label', 'Move right');
      right.textContent = '›';
      right.disabled = idx === selected.length - 1;
      right.addEventListener('click', (e) => {
        e.stopPropagation();
        moveItem(idx, idx + 1);
      });

      item.addEventListener('dragstart', (e) => {
        dragFrom = idx;
        item.classList.add('dragging');
        if (e.dataTransfer) {
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', String(idx));
        }
      });

      item.addEventListener('dragend', () => {
        dragFrom = -1;
        item.classList.remove('dragging');
        previewGrid.querySelectorAll('.preview-item').forEach((el) => el.classList.remove('drag-over'));
      });

      item.addEventListener('dragover', (e) => {
        e.preventDefault();
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
        if (dragFrom !== -1 && dragFrom !== idx) item.classList.add('drag-over');
      });

      item.addEventListener('dragleave', () => {
        item.classList.remove('drag-over');
      });

      item.addEventListener('drop', (e) => {
        e.preventDefault();
        e.stopPropagation();
        item.classList.remove('drag-over');
        if (dragFrom === -1 || dragFrom === idx) return;
        moveItem(dragFrom, idx);
      });

      item.appendChild(img);
      item.appendChild(order);
      item.appendChild(remove);
      item.appendChild(left);
      item.appendChild(right);
      previewGrid.appendChild(item);
    });

    previewHint.style.display = selected.length >= 2 ? 'block' : 'none';
    dropzoneText.textContent = selected.length === 0
      ? 'Drop up to 3 photos here or click to browse'
      : `${selected.length} of ${MAX_PHOTOS} selected — click to add more`;
  }

  function showAlert(type: string, message: string) {
    alertBox.className = `alert alert-${type}`;
    alertBox.textContent = message;
    alertBox.style.display = 'block';
  }

  function hideAlert() {
    alertBox.style.display = 'none';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideAlert();

    if (selected.length === 0) {
      showAlert('error', 'Please select at least one photo.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'SUBMITTING...';

    const formData = new FormData(form);
    // Replace any auto-collected photos with our managed list (ensures order + dedupe)
    formData.delete('photos');
    selected.forEach((f) => formData.append('photos', f));

    try {
      const res = await fetch('/api/submit', { method: 'POST', body: formData });
      const data = await res.json();

      if (res.ok) {
        form.reset();
        selected = [];
        renderPreviews();
        modal.style.display = 'flex';
      } else {
        showAlert('error', data.error || 'Something went wrong. Please try again.');
      }
    } catch {
      showAlert('error', 'Network error. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND THE DUCK 🦆';
    }
  });

  modalClose.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });
</script>
